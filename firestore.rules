rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regras para a coleção de produtos
    match /produtos/{document} {
      // Qualquer um pode ler os produtos (vendedores externos e clientes na vitrine)
      allow read: if true;
      
      // Apenas o administrador autenticado com o e-mail 'edenirm@gmail.com' pode alterar os dados
      allow write: if request.auth != null && request.auth.token.email == 'edenirm@gmail.com';
    }
  }
}
