rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regras para a coleção de produtos
    match /produtos/{document} {
      // Qualquer um pode ler os produtos (vendedores externos e clientes na vitrine)
      allow read: if true;
      
      // Apenas os e-mails autorizados podem alterar os dados
      allow write: if request.auth != null && (
        request.auth.token.email == 'edenirm@gmail.com' || 
        request.auth.token.email == 'atacadofacilita21@gmail.com' || 
        request.auth.token.email == 'michele.wilwert@gmail.com' || 
        request.auth.token.email == 'adilsonwilwert@gmail.com'
      );
    }

    // Regras para a coleção de categorias
    match /categorias/{document} {
      // Qualquer um pode ler as categorias
      allow read: if true;
      
      // Apenas os e-mails autorizados podem alterar os dados
      allow write: if request.auth != null && (
        request.auth.token.email == 'edenirm@gmail.com' || 
        request.auth.token.email == 'atacadofacilita21@gmail.com' || 
        request.auth.token.email == 'michele.wilwert@gmail.com' || 
        request.auth.token.email == 'adilsonwilwert@gmail.com'
      );
    }
  }
}
